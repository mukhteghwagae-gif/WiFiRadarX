<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:id="@+id/layout_device_hunter"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🎯 Interference Hunt Mode"
            android:textColor="@color/primary"
            android:textSize="18sp" android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Walk to a spot → tap its cell → repeat from ≥ 3 positions"
            android:textColor="#888888" android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <!-- Source result card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/surface">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:id="@+id/tv_source_info"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Tap grid cells at your current position\nto add measurements (need ≥ 3)."
                    android:textColor="@color/on_surface"
                    android:textSize="14sp" android:lineSpacingMultiplier="1.5" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView android:id="@+id/tv_measurement_count"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="0 / 3+ measurements collected"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp" android:layout_marginBottom="12dp" />

        <!-- FIX: FrameLayout placeholder for the programmatic tap-grid -->
        <FrameLayout
            android:id="@+id/fl_hunter_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <Button android:id="@+id/btn_reset_hunt"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Reset Hunt" />

    </LinearLayout>
</ScrollView>
