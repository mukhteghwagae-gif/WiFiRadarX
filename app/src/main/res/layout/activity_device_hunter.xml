<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_device_hunter"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical" android:padding="16dp">
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="🎯 Interference Hunt Mode" android:textColor="@color/primary"
        android:textSize="18sp" android:textStyle="bold" android:layout_marginBottom="12dp" />
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp" app:cardBackgroundColor="@color/surface">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">
            <TextView android:id="@+id/tv_source_info"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Collecting measurements…" android:textColor="@color/on_surface"
                android:textSize="14sp" android:lineSpacingMultiplier="1.5" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
    <TextView android:id="@+id/tv_measurement_count"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="0 measurements" android:textColor="@color/on_surface_variant"
        android:textSize="13sp" android:layout_marginBottom="16dp" />
    <Button android:id="@+id/btn_reset_hunt" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="Reset Hunt" />
</LinearLayout>
