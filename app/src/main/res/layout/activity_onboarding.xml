<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:id="@+id/iv_onboard_icon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_wifi_scan"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/tv_onboard_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Title"
        android:textColor="@color/primary"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_onboard_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:text="Description"
        android:textColor="@color/on_surface"
        android:textSize="16sp"
        android:layout_marginBottom="48dp" />

    <!-- Dot indicators -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <View android:id="@+id/dot1"
            android:layout_width="10dp" android:layout_height="10dp"
            android:layout_margin="4dp"
            android:background="@drawable/dot_indicator" />
        <View android:id="@+id/dot2"
            android:layout_width="10dp" android:layout_height="10dp"
            android:layout_margin="4dp"
            android:background="@drawable/dot_indicator" />
        <View android:id="@+id/dot3"
            android:layout_width="10dp" android:layout_height="10dp"
            android:layout_margin="4dp"
            android:background="@drawable/dot_indicator" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_next"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Next"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_skip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Skip"
        style="@style/Widget.Material3.Button.TextButton"
        android:textColor="@color/on_surface_variant" />

</LinearLayout>
