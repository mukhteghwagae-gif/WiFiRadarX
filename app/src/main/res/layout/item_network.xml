<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Row 1: SSID + Security badge -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView android:id="@+id/tv_ssid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/on_surface"
                android:textSize="15sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="SSID" />

            <TextView android:id="@+id/tv_security"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="SECURE"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Row 2: BSSID + RSSI -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView android:id="@+id/tv_bssid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:text="00:00:00:00:00:00" />

            <TextView android:id="@+id/tv_rssi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:text="-- dBm" />
        </LinearLayout>

        <!-- Row 3: Channel + Band + Vendor -->
        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView android:id="@+id/tv_channel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:text="Ch --"
                android:layout_marginEnd="10dp" />

            <TextView android:id="@+id/tv_band"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/secondary"
                android:textSize="11sp"
                android:text="2.4 GHz"
                android:layout_marginEnd="10dp" />

            <TextView android:id="@+id/tv_vendor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="Unknown" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
