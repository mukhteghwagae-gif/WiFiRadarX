<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <android.opengl.GLSurfaceView
        android:id="@+id/gl_surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/tv_ar_fallback"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:padding="32dp"
        android:text="ARCore not available on this device.\nWiFi mapping data is still being collected."
        android:textColor="@color/on_surface"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Controls overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#AA07090F"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <CheckBox android:id="@+id/cb_heatmap"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Heatmap" android:textColor="@color/on_surface"
                android:checked="true" />
            <CheckBox android:id="@+id/cb_voxels"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Voxels" android:textColor="@color/on_surface" />
            <CheckBox android:id="@+id/cb_arrow"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Arrow" android:textColor="@color/on_surface"
                android:checked="true" />
            <ToggleButton android:id="@+id/toggle_predict"
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textOn="IDW ON" android:textOff="IDW OFF"
                android:textColor="@color/on_surface" />
        </LinearLayout>

        <TextView android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Height Slice"
            android:textColor="@color/on_surface_variant"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <SeekBar android:id="@+id/seek_height_slice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progress="50" />

        <Button android:id="@+id/btn_ar_scan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Capture Position"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</FrameLayout>
