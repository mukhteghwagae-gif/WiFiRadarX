<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardBackgroundColor="@color/surface"
            app:cardElevation="4dp"
            app:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/tv_scan_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="WiFi: ON"
                        android:textColor="@color/primary"
                        android:textSize="14sp" />
                    <TextView
                        android:id="@+id/tv_network_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 networks"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="14sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_best_signal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Scanning…"
                    android:textColor="@color/on_surface"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_rogue_alert"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="⚠ Rogue AP detected"
                    android:textColor="#FF4444"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Quick Actions Grid -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="8dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_ar"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="12dp"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_ar_view"
                            app:tint="@color/primary" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AR Mapping"
                            android:textColor="@color/on_surface"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_radar"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="12dp"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_radar"
                            app:tint="@color/primary" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Live Radar"
                            android:textColor="@color/on_surface"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_heatmap"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="12dp"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_heatmap"
                            app:tint="@color/secondary" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Heatmap"
                            android:textColor="@color/on_surface"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_mesh"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="12dp"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_mesh"
                            app:tint="@color/secondary" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mesh Optimizer"
                            android:textColor="@color/on_surface"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_hunter"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="12dp"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_hunter"
                            app:tint="@color/error" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Device Hunter"
                            android:textColor="@color/on_surface"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_timelapse"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="12dp"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_timelapse"
                            app:tint="@color/primary" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time Lapse"
                            android:textColor="@color/on_surface"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_settings"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_margin="6dp"
                    app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="12dp"
                    android:layout_columnWeight="1">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_settings"
                            app:tint="@color/on_surface_variant" />
                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Settings"
                            android:textColor="@color/on_surface"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>
        </ScrollView>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            app:itemIconTint="@color/nav_item_color"
            app:itemTextColor="@color/nav_item_color"
            app:menu="@menu/bottom_nav_menu" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_scan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="80dp"
        android:src="@drawable/ic_wifi_scan"
        app:backgroundTint="@color/primary"
        app:tint="@color/background" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
