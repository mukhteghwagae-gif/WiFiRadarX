<?xml version="1.0" encoding="utf-8"?>
<!-- activity_live_radar.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/background" android:orientation="vertical">

    <com.wifiradarx.app.ui.views.RadarView
        android:id="@+id/radar_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:orientation="horizontal"
        android:padding="12dp">
        <TextView android:id="@+id/tv_radar_count"
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 networks" android:textColor="@color/primary" />
        <Button android:id="@+id/btn_radar_scan"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Scan" android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
