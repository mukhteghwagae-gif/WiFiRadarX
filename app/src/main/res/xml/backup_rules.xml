<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!--
        Back up shared preferences only.
        Exclude the Room database (large, device-specific, rebuilt on install).
        Exclude all other files (cache, temp, native libs).
    -->
    <include domain="sharedpref" path="." />
    <include domain="database"   path="." />
    <include domain="file"       path="." />

    <exclude domain="database" path="wifiradarx.db" />
    <exclude domain="database" path="wifiradarx.db-shm" />
    <exclude domain="database" path="wifiradarx.db-wal" />
    <exclude domain="file"     path="." />
</full-backup-content>
