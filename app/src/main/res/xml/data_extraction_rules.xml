<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!--
        Cloud backup: include shared preferences, exclude Room database.
    -->
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <include domain="database"   path="." />
        <exclude domain="database"   path="wifiradarx.db" />
        <exclude domain="database"   path="wifiradarx.db-shm" />
        <exclude domain="database"   path="wifiradarx.db-wal" />
    </cloud-backup>

    <!--
        Device-to-device transfer: same rules.
    -->
    <device-transfer>
        <include domain="sharedpref" path="." />
        <include domain="database"   path="." />
        <exclude domain="database"   path="wifiradarx.db" />
        <exclude domain="database"   path="wifiradarx.db-shm" />
        <exclude domain="database"   path="wifiradarx.db-wal" />
    </device-transfer>
</data-extraction-rules>
